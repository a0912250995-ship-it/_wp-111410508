<h1>My Blog</h1>
<% if (posts.length === 0) { %>
  <p>No posts yet.</p>
<% } else { %>
  <ul class="post-list">
    <% posts.forEach(post => { %>
      <li>
        <h2><a href="/posts/<%= post.id %>"><%= post.title %></a></h2>
        <p class="meta"><%= post.created_at %></p>
      </li>
    <% }) %>
  </ul>
<% } %>
