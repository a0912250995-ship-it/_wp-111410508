<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title><%= typeof title !== 'undefined' ? title : 'Threads' %></title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="container">
    <div class="header">
      <h1><%= typeof title !== 'undefined' ? title : 'Threads' %></h1>
      <div class="header-actions">
        <% if (user) { %>
          <div class="user-badge">
            <a href="/profile"><%= user.username %></a>
          </div>
          <a href="/logout">Log out</a>
        <% } else { %>
          <a href="/login">Log in</a>
          <a href="/register" class="btn-primary">Sign up</a>
        <% } %>
      </div>
    </div>

    <div class="content">
      <%- body %>
    </div>

    <nav class="bottom-nav">
      <a href="/" class="<%= typeof page === 'undefined' || page === 'home' ? 'active' : '' %>">
        <span class="nav-icon">&#9751;</span>
        <span>Feed</span>
      </a>
      <a href="/profile" class="<%= typeof page === 'profile' ? 'active' : '' %>">
        <span class="nav-icon">&#128100;</span>
        <span>Profile</span>
      </a>
    </nav>
  </div>
</body>
</html>
